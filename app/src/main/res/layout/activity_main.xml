<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Camera Preview (fills screen) ─────────────────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Top gradient scrim ─────────────────────────────────────────── -->
    <View
        android:id="@+id/topGradient"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bottom gradient scrim ──────────────────────────────────────── -->
    <View
        android:id="@+id/bottomGradient"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── REC dot ────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/recordingIndicator"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/recording_dot"
        android:visibility="gone"
        android:layout_marginTop="18dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── REC text ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/recordingTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REC"
        android:textColor="#FF3B30"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:visibility="gone"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/recordingIndicator"
        app:layout_constraintBottom_toBottomOf="@id/recordingIndicator"
        app:layout_constraintStart_toEndOf="@id/recordingIndicator" />

    <!-- ── HUD: Horizon line indicator (tilts with real world) ────────── -->
    <View
        android:id="@+id/horizonLine"
        android:layout_width="100dp"
        android:layout_height="2dp"
        android:background="@drawable/horizon_line"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/angleReadout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── HUD: Tilt/Angle readout ────────────────────────────────────── -->
    <TextView
        android:id="@+id/angleReadout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Perfectly Level"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.05"
        android:alpha="0.90"
        android:layout_marginBottom="22dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bottom controls bar ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Lock toggle + label -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/lockToggle"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_lock"
                android:background="@drawable/btn_circle_bg"
                android:padding="13dp"
                android:contentDescription="Toggle Horizon Lock" />

            <TextView
                android:id="@+id/lockStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lock_on"
                android:textColor="@color/lock_active"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="7dp" />
        </LinearLayout>

        <!-- Record button (big, center) -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">
            <ImageButton
                android:id="@+id/recordButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_record"
                android:background="@drawable/btn_record_bg"
                android:padding="20dp"
                android:contentDescription="Record video" />
        </FrameLayout>

        <!-- Gallery button (mirrors lock button, opens saved videos) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/galleryButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_gallery"
                android:background="@drawable/btn_circle_bg"
                android:padding="13dp"
                android:contentDescription="Open Gallery" />

            <TextView
                android:id="@+id/galleryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gallery"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="7dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
